# Supabase project origin (the code also normalizes a pasted /rest/v1 URL).
# Used server-side only; the anon key needs read access to both mapped tables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Structured source of truth for therapist facts.
SUPABASE_THERAPIST_TABLE=therapist_data
# Structured safety reference source for EthicalGuardianAgent.
SUPABASE_GUARDIAN_TABLE=mental_health_diagnosis_treatment

# Pinecone API key (server-side only).
PINECONE_API_KEY=
# Legacy therapist-vector adapter only; not used for document knowledge.
PINECONE_INDEX=therapists
# Optional legacy therapist-vector namespace.
PINECONE_NAMESPACE=
# Agent knowledge RAG. Records must include text, source_file and
# agent_targets metadata. Default index: mentalink-data.
PINECONE_KNOWLEDGE_INDEX=mentalink-data
PINECONE_KNOWLEDGE_NAMESPACE=

# LLMod.ai (LLM provider) — server-side only, never exposed to the frontend
LLMOD_API_KEY=
# OpenAI-compatible base URL of the LLMod gateway (default: https://api.llmod.ai/v1)
LLMOD_BASE_URL=
# Per-request timeout in milliseconds (default: 40000 — keeps the worst-case
# 7 requests of one /api/execute run under Vercel's 300-second limit)
LLMOD_TIMEOUT_MS=

# Optional: verified local crisis resources shown in the crisis safety response.
# JSON array of strings. The system never invents emergency phone numbers.
# Example: CRISIS_RESOURCES=["Emergency services: 101","ERAN emotional first aid: 1201"]
CRISIS_RESOURCES=

# Optional: number of candidates retrieved from Pinecone before ranking (default: 10)
RETRIEVAL_TOP_K=

# Optional bounded context settings.
KNOWLEDGE_TOP_K=8
MAX_KNOWLEDGE_CHARS=6000
MAX_KNOWLEDGE_CHUNK_CHARS=1800
THERAPIST_SCAN_LIMIT=50
MATCHMAKER_CANDIDATE_LIMIT=10
GUARDIAN_REFERENCE_SCAN_LIMIT=40
GUARDIAN_REFERENCE_LIMIT=6
